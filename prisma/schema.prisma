generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("STAFF")
  avatar        String?
  isApproved    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Employee profile fields
  firstName     String?
  lastName      String?
  displayName   String?
  nickname      String?
  phone         String?
  position      String?
  bio           String?
  skills        String?   // comma-separated: "Management,Strategy,Creative Direction"
  gender        String?   // ชาย, หญิง, LGBTQ
  birthday      DateTime?
  address       String?
  idCardImageUrl String?
  fatherName    String?
  motherName    String?
  salaryAccountNo String?
  bankAccount   String?
  maritalStatus String?   // โสด, สมรส, สมรส มีบุตร
  themeColor    String?   // e.g. "purple", "blue", "pink"

  ownedProjects      Project[]        @relation("ProjectOwner")
  projectMemberships ProjectMember[]
  assignedTasks      TaskAssignee[]
  taskComments       TaskComment[]
  createdTasks       Task[]           @relation("TaskCreator")
  notifications      Notification[]

  // Rewards
  createdRewards      Reward[]            @relation("RewardCreator")
  rewardAssignments   RewardAssignment[]  @relation("RewardAssignee")
  assignedRewards     RewardAssignment[]  @relation("RewardAssigner")
  rewardClaims        RewardClaim[]       @relation("RewardClaimer")
  reviewedClaims      RewardClaim[]       @relation("RewardReviewer")
}

model Client {
  id           String    @id @default(cuid())
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  businessType String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects Project[]
  revenues Revenue[]
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  clientId    String
  ownerId     String
  statusId    String
  isCompleted Boolean   @default(false)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client   Client          @relation(fields: [clientId], references: [id])
  owner    User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  status   MasterData      @relation(fields: [statusId], references: [id])
  members  ProjectMember[]
  tasks    Task[]
  revenues Revenue[]
}

model Task {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  description String?
  progress    Int       @default(0)
  statusId    String?
  categoryId  String?
  createdById String?
  dueDate     DateTime?
  isClosed    Boolean   @default(false)
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project          @relation(fields: [projectId], references: [id])
  status      MasterData?      @relation("TaskStatus", fields: [statusId], references: [id])
  category    MasterData?      @relation("TaskCategory", fields: [categoryId], references: [id])
  createdBy   User?            @relation("TaskCreator", fields: [createdById], references: [id])
  assignees   TaskAssignee[]
  comments    TaskComment[]
  attachments TaskAttachment[]
}

model ProjectMember {
  id        String @id @default(cuid())
  projectId String
  userId    String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model TaskAssignee {
  id     String @id @default(cuid())
  taskId String
  userId String

  task Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  type      String
  url       String
  name      String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Revenue {
  id           String    @id @default(cuid())
  clientId     String
  projectId    String?
  amount       Float
  date         DateTime
  type         String
  description  String?
  isConfirmed  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  client  Client   @relation(fields: [clientId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
}

model MasterData {
  id        String    @id @default(cuid())
  category  String
  name      String
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects      Project[]
  tasks         Task[]    @relation("TaskStatus")
  categoryTasks Task[]    @relation("TaskCategory")
}

model Reward {
  id          String   @id @default(cuid())
  name        String
  description String?
  amount      Float
  frequency   String   // MONTHLY, YEARLY, ONE_TIME
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User               @relation("RewardCreator", fields: [createdById], references: [id])
  assignments RewardAssignment[]
}

model RewardAssignment {
  id           String   @id @default(cuid())
  rewardId     String
  userId       String
  assignedById String
  isActive     Boolean  @default(true)
  assignedAt   DateTime @default(now())

  reward     Reward        @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  user       User          @relation("RewardAssignee", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User          @relation("RewardAssigner", fields: [assignedById], references: [id])
  claims     RewardClaim[]

  @@unique([rewardId, userId])
}

model RewardClaim {
  id           String    @id @default(cuid())
  assignmentId String
  claimedById  String
  period       String    // "2026-03" for MONTHLY, "2026" for YEARLY, "once" for ONE_TIME
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED
  note         String?
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  claimedAt    DateTime  @default(now())

  assignment RewardAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  claimedBy  User             @relation("RewardClaimer", fields: [claimedById], references: [id])
  reviewedBy User?            @relation("RewardReviewer", fields: [reviewedById], references: [id])

  @@unique([assignmentId, period])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // NEW_REGISTRATION, PROJECT_ASSIGN, TASK_ASSIGN
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
